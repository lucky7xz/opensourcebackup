# ==============================================================================
# OpenSourceBackup — Control Plane Configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
# ==============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgres://opensourcebackup:dev_password@localhost:5432/opensourcebackup?sslmode=disable

# ── Network ───────────────────────────────────────────────────────────────────
# Address the server listens on. Use :8443 when TLS is enabled.
LISTEN_ADDR=:8080

# When TLS is enabled, optionally redirect HTTP to HTTPS.
# Example: TLS on :8443, redirect from :8080
# HTTP_REDIRECT_ADDR=:8080

# ── TLS (strongly recommended for production) ─────────────────────────────────
# Both must be set to enable HTTPS. Leave empty for HTTP (dev only).
#
# Dev cert (self-signed, localhost + LAN IP):
#   go run ./internal/tools/gencert/ 192.168.1.100
#   TLS_CERT_FILE=certs/dev.crt
#   TLS_KEY_FILE=certs/dev.key
#
# Production (Let's Encrypt):
#   TLS_CERT_FILE=/etc/letsencrypt/live/domain/fullchain.pem
#   TLS_KEY_FILE=/etc/letsencrypt/live/domain/privkey.pem
#
# TLS_CERT_FILE=
# TLS_KEY_FILE=

# Refuse startup in HTTP mode. Prevents accidental plaintext in production.
# TLS_REQUIRED=true

# ── Authentication ────────────────────────────────────────────────────────────
# Dashboard admin password. bcrypt (cost 12) applied at startup.
# EMPTY = no authentication — DEV/LOCAL ONLY. Never leave empty in production.
# ADMIN_PASSWORD=change-me-before-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed CORS origin.
# Dev: http://localhost:5173 (Vite dev server)
# Prod: your dashboard URL, e.g. https://backup.example.com
CORS_ORIGIN=http://localhost:5173

# ── Web UI ────────────────────────────────────────────────────────────────────
# Path to built web UI (dist/ directory). Empty = no built-in UI (dev mode).
# WEB_UI_DIR=/opt/opensourcebackup/web-ui

# ==============================================================================
# Agent Configuration (set on each system running the agent)
# ==============================================================================

# Control Plane URL the agent connects to.
# Use HTTPS in production: https://backup.yourserver.com:8443
CONTROL_PLANE_URL=http://localhost:8080

# Backup encryption password.
# CRITICAL: Never lose this. Without it, restores are impossible.
# RESTIC_PASSWORD=change-me-and-store-safely

# Backup destination. Restic supports: local path, s3:, sftp:, b2:, azure:, gs:
# RESTIC_REPO=/var/backups/restic-repo

# One-time enrollment token — from the dashboard Agents wizard (first run only).
# ENROLLMENT_TOKEN=

# Path to the permanent agent token (saved after enrollment).
# AGENT_TOKEN_FILE=data/agent-token

# How often the agent polls for jobs and sends heartbeats. Default: 30s
# AGENT_POLL_INTERVAL=30s

# Sandbox directory for restore tests.
# RESTORE_TEST_ROOT=data/restore-tests

# Path to restic binary. Auto-detected from PATH if not set.
# RESTIC_BIN=/usr/local/bin/restic

# Skip TLS certificate verification — DEV ONLY with self-signed certs.
# NEVER use in production.
# AGENT_TLS_SKIP_VERIFY=true
