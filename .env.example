# Control Plane
DATABASE_URL=postgres://opensourcebackup:dev_password@localhost:5432/opensourcebackup?sslmode=disable
LISTEN_ADDR=:8080
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

# TLS (optional — leave empty for HTTP dev mode)
# Generate dev certificate: make certs
TLS_CERT_FILE=
TLS_KEY_FILE=
# For HTTPS: set LISTEN_ADDR=:8443 and fill in cert/key paths

# Agent
CONTROL_PLANE_URL=http://localhost:8080
RESTIC_PASSWORD=your-strong-password-here
RESTIC_REPO=s3:your-bucket/backups/system-name
RESTIC_BIN=restic
AGENT_POLL_INTERVAL=30s
RESTORE_TEST_ROOT=data/restore-tests

# TLS for agent (dev only — never in production)
AGENT_TLS_SKIP_VERIFY=false

# Token (eine der drei Optionen):
AGENT_TOKEN=          # direkt setzen (höchste Priorität)
AGENT_TOKEN_FILE=data/agent-token   # oder Pfad zur Token-Datei
ENROLLMENT_TOKEN=     # oder Enrollment-Token zum erstmaligen Enrollen
